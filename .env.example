# =====================================================================
# Sweep Haus Bearer Token(s)
# Get from DevTools → Network tab while browsing sweep.haus
# Use BEARER for single token, or BEARER_1/2/3... for multiple (rotated round-robin)
# =====================================================================

BEARER=your_sweep_haus_bearer_token_here

# Multiple tokens (comment out BEARER above and use these instead)
# BEARER_1=token_one_here
# BEARER_2=token_two_here
# BEARER_3=token_three_here

# =====================================================================
# Sweep Haus Platform Fee (optional override)
# Default: 202000000000000 wei (0.000202 native tokens)
# Only change this if Sweep Haus updates their fee — no code change needed
# =====================================================================

# SWEEP_FEE=202000000000000

# =====================================================================
# Loop Mode (optional — can also use --loop CLI flag)
# =====================================================================

# LOOP=true
# LOOP_INTERVAL_HOURS=24

# =====================================================================
# Telegram Alerts (optional)
# Sends alerts on: bearer expiry, RPC failure, run summary, startup
#
# Setup:
#   1. Create bot via @BotFather in Telegram → copy BOT_TOKEN
#   2. Send any message to your bot, then open:
#      https://api.telegram.org/bot<BOT_TOKEN>/getUpdates
#      Copy the "id" field from "chat" → that is your CHAT_ID
# =====================================================================

# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# TELEGRAM_CHAT_ID=987654321
